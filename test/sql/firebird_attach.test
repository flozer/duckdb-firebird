# name: test/sql/firebird_attach.test
# description: native ATTACH ... AS x (TYPE firebird) support
# group: [firebird]

require firebird

require-env FIREBIRD_TEST_DB

require-env ISC_PASSWORD

# --- Attach ----------------------------------------------------------------

statement ok
ATTACH '${FIREBIRD_TEST_DB}' AS fb (TYPE firebird);

# Information schema sees the Firebird tables.
query I
SELECT COUNT(*) > 0 FROM information_schema.tables
 WHERE table_catalog = 'fb' AND table_name = 'EMPLOYEE';
----
true

# Only the "main" schema is exposed.
query I
SELECT schema_name FROM information_schema.schemata WHERE catalog_name = 'fb';
----
main

# DESCRIBE surfaces the real Firebird column shape, not a placeholder.
query III
SELECT column_name, data_type, is_nullable
  FROM information_schema.columns
 WHERE table_catalog = 'fb' AND table_name = 'EMPLOYEE'
 ORDER BY ordinal_position;
----
EMP_ID	INTEGER	NO
EMP_NAME	VARCHAR	NO
DEPT_NO	VARCHAR	YES
SALARY	DECIMAL(18,2)	YES
HIRE_DATE	DATE	YES
ACTIVE	BOOLEAN	YES
NOTE	VARCHAR	YES
NAME_LEN	INTEGER	YES

# --- Reads through the attached catalog ------------------------------------

query II
SELECT EMP_ID, EMP_NAME FROM fb.main.EMPLOYEE WHERE DEPT_NO = '600' ORDER BY EMP_ID;
----
1	Alice Andersson
2	Bob Brown
4	Diana Davis

# COUNT(*) hits the rowid-only projection path — guards against the
# INT32/INT64 type-mismatch regression that bit the first ATTACH cut.
query I
SELECT COUNT(*) FROM fb.main.EMPLOYEE;
----
5

# Case-insensitive resolution: identifier comes in lowercased / quoted /
# upper, all hit the same table.
query I
SELECT COUNT(*) FROM fb.main.employee;
----
5

query I
SELECT COUNT(*) FROM fb.main."EMPLOYEE";
----
5

# GROUP BY across the bridge — confirms the table is fully usable in
# DuckDB's executor, not just trivial SELECTs.
query II
SELECT DEPT_NO, COUNT(*)
  FROM fb.main.EMPLOYEE
 GROUP BY DEPT_NO
 ORDER BY DEPT_NO;
----
600	3
700	1
900	1

# --- Federated join with a local TEMP table --------------------------------

statement ok
CREATE TEMP TABLE dept(d VARCHAR, label VARCHAR);

statement ok
INSERT INTO dept VALUES ('600','Engineering'),('700','Sales'),('900','Ops');

query II
SELECT e.EMP_NAME, d.label
  FROM fb.main.EMPLOYEE e
  JOIN dept d ON e.DEPT_NO = d.d
 ORDER BY e.EMP_ID;
----
Alice Andersson	Engineering
Bob Brown	Engineering
Carlos Chen	Ops
Diana Davis	Engineering
Erik Eklund	Sales

# --- Read-only enforcement --------------------------------------------------

statement error
CREATE TABLE fb.main.NEW_TABLE (id INT);
----
read-only

statement error
DROP TABLE fb.main.EMPLOYEE;
----

# --- Schema lookup errors give a helpful message ---------------------------

statement error
SELECT * FROM fb.public.EMPLOYEE LIMIT 1;
----

# --- Detach restores clean state -------------------------------------------

statement ok
DETACH fb;

statement error
SELECT * FROM fb.main.EMPLOYEE LIMIT 1;
----

# --- Re-attach: the pool tears down cleanly and re-opens fine -------------
# Guards against leaking idle connections / stale catalog state when the
# user attaches a Firebird database, detaches, then attaches it again
# inside the same DuckDB session.

statement ok
ATTACH '${FIREBIRD_TEST_DB}' AS fb (TYPE firebird);

query I
SELECT COUNT(*) FROM fb.main.EMPLOYEE;
----
5

statement ok
DETACH fb;

statement ok
ATTACH '${FIREBIRD_TEST_DB}' AS fb (TYPE firebird);

query II
SELECT EMP_ID, EMP_NAME FROM fb.main.EMPLOYEE WHERE EMP_ID = 1;
----
1	Alice Andersson

# --- Views via ATTACH ------------------------------------------------------
# Views (RDB$RELATION_TYPE=1) appear in the attached catalog and scan
# exactly like regular tables.

query I
SELECT COUNT(*) FROM information_schema.tables
 WHERE table_catalog = 'fb' AND table_name = 'V_ACTIVE_EMP';
----
1

query III
SELECT EMP_ID, EMP_NAME, DEPT_NO FROM fb.main.V_ACTIVE_EMP ORDER BY EMP_ID;
----
1	Alice Andersson	600
2	Bob Brown	600
4	Diana Davis	600
5	Erik Eklund	700

# ---------------------------------------------------------------------------
#  Type Lossless Hardening (#33), ATTACH path: the standalone
#  firebird_scan(...) call path and the ATTACH-resolved fb.main.TABLE path
#  bind through two DIFFERENT code paths (FirebirdScanBind vs
#  FirebirdTableEntry::GetScanFunction) -- a fix in only one does not cover
#  the other. This is the exact repro form from the original bug report.
#
#  A typeof()-only check is not sufficient here: DuckDB's planner derives
#  the whole query's Vector types (LogicalGet::return_types) from the
#  catalog entry's OWN persistent column list (TableCatalogEntry::columns),
#  not from the scan's FunctionData alone -- so reconciling only the bind
#  data (the way the standalone firebird_scan(...) fix does) is NOT enough
#  for the ATTACH path: it silently corrupts values instead of crashing
#  (narrower fetched bytes get Reference()'d into the output chunk and are
#  reinterpreted downstream at the stale wider catalog type -- confirmed
#  live during development: a bind-data-only fix produced no crash but
#  printed "1313408178048120075825702.25" instead of a real payroll sum).
#  The value cross-check below (same fan-out math as firebird_scan.test)
#  proves the actual DATA survives correctly, not just that the reported
#  type looks right.
# ---------------------------------------------------------------------------

# RACE33-ATTACH: prove view columns are finalized BEFORE the catalog entry
# is published, not lazily reconciled on first scan. information_schema.
# columns reads TableCatalogEntry::GetColumns() directly and does not go
# through FirebirdTableEntry::GetScanFunction -- this is the FIRST touch
# of V_DEPT_HEADCOUNT anywhere in this test file (nothing above this line
# references that relation), and no SELECT against it has run yet. Under
# the pre-fix design (reconciliation happened lazily inside
# GetScanFunction, mutating the shared, already-published entry's columns
# in place on first scan) an introspection read that never triggers a
# scan would have observed the stale, unreconciled DECIMAL(38,2) here.
# Observing the reconciled DECIMAL(18,2) precision/scale with zero prior
# scans proves reconciliation is baked in at publish time
# (FirebirdSchemaEntry::EnsureTablesLoaded's add_entry lambda) and can no
# longer be scan-triggered.
query III
SELECT column_name, numeric_precision, numeric_scale
  FROM information_schema.columns
 WHERE table_catalog = 'fb' AND table_name = 'V_DEPT_HEADCOUNT'
   AND column_name = 'TOTAL_SALARY';
----
TOTAL_SALARY	18	2

query I
SELECT typeof(TOTAL_SALARY) = 'DECIMAL(18,2)'
  FROM fb.main.V_DEPT_HEADCOUNT LIMIT 1;
----
true

# Independent value cross-check: V_DEPT_HEADCOUNT is a self-join (EMPLOYEE e
# JOIN EMPLOYEE m ON m.DEPT_NO = e.DEPT_NO, GROUP BY e.DEPT_NO -- see
# scripts/setup_test_firebird.sh), so each department's TOTAL_SALARY is
# headcount * sum(salary) for that department. This reproduces that
# fan-out directly from EMPLOYEE (never touching the view's own frozen
# catalog type), proving the reconciled VALUE is exactly right, not just
# "didn't crash".
query I
SELECT SUM(TOTAL_SALARY) = (
    SELECT SUM(cnt * total)
      FROM (SELECT COUNT(*) AS cnt, SUM(SALARY) AS total
              FROM fb.main.EMPLOYEE
             GROUP BY DEPT_NO)
  )
  FROM fb.main.V_DEPT_HEADCOUNT;
----
true

# Run a DIFFERENTLY-SHAPED query (column subset + WHERE filter, not
# SELECT *) against the SAME memoized catalog entry, to prove the
# once-per-entry reconciliation (guarded by the pk_loaded_ latch in
# FirebirdTableEntry::GetScanFunction) is correct for any future query
# shape against this view, not just the one that happened to run first.
query I
SELECT TOTAL_SALARY FROM fb.main.V_DEPT_HEADCOUNT WHERE DEPT_NO = '600';
----
766502.25

# Materialized-view pattern via CTAS — once cached locally, queries are
# free of Firebird round-trips.
statement ok
CREATE OR REPLACE TABLE main.mv_active_emp AS SELECT * FROM fb.main.V_ACTIVE_EMP;

query I
SELECT COUNT(*) FROM main.mv_active_emp;
----
4

statement ok
DROP TABLE main.mv_active_emp;

statement ok
DETACH fb;
