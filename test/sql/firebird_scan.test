# name: test/sql/firebird_scan.test
# description: end-to-end tests for the firebird_scan table function
# group: [firebird]
#
# Requires the EMPLOYEE fixture from scripts/setup_test_firebird.sh and the
# following environment variables:
#   FIREBIRD_TEST_DB   absolute path to a Firebird .fdb file
#   ISC_PASSWORD       SYSDBA password
# CI populates them via scripts/setup_test_firebird.sh; locally you can
# `source` the output of the script.

require firebird

require-env FIREBIRD_TEST_DB

require-env ISC_PASSWORD

# --- Basic scan -------------------------------------------------------------

query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE');
----
5

# Type roundtrip: INTEGER, VARCHAR, VARCHAR, DECIMAL, DATE, BOOLEAN.
query IIIIII
SELECT EMP_ID, EMP_NAME, DEPT_NO, SALARY, HIRE_DATE, ACTIVE
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 ORDER BY EMP_ID;
----
1	Alice Andersson	600	75000.50	2020-03-15	true
2	Bob Brown	600	82500.00	2019-07-01	true
3	Carlos Chen	900	65000.75	2022-11-20	false
4	Diana Davis	600	98000.25	2018-01-10	true
5	Erik Eklund	700	71200.00	2021-06-30	true

# BLOB SUB_TYPE 1 (text) — full read.
query I
SELECT NOTE FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE') WHERE EMP_ID = 1;
----
Senior developer

# NULL handling.
query II
SELECT EMP_ID, NOTE FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE NOTE IS NULL ORDER BY EMP_ID;
----
2	NULL
5	NULL

# --- Filter pushdown -------------------------------------------------------

# Equality on VARCHAR.
query II
SELECT EMP_ID, EMP_NAME FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE DEPT_NO = '600' ORDER BY EMP_ID;
----
1	Alice Andersson
2	Bob Brown
4	Diana Davis

# Range on DECIMAL (BETWEEN — DuckDB splits into >= AND <=).
query II
SELECT EMP_ID, SALARY FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE SALARY BETWEEN 70000 AND 90000 ORDER BY EMP_ID;
----
1	75000.50
2	82500.00
5	71200.00

# AND / OR.
query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE (DEPT_NO = '600' AND SALARY > 80000) OR DEPT_NO = '700';
----
3

# DATE comparison.
query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE HIRE_DATE >= DATE '2020-01-01';
----
3

# BOOLEAN comparison.
query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE') WHERE ACTIVE = FALSE;
----
1

# IN list — translated to `col IN (a, b)` SQL on the Firebird side.
query II
SELECT EMP_ID, EMP_NAME FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE DEPT_NO IN ('600','900') ORDER BY EMP_ID;
----
1	Alice Andersson
2	Bob Brown
3	Carlos Chen
4	Diana Davis

# IN with mismatched value type — should still return correct rows
# (DuckDB will re-evaluate above the scan if pushdown failed).
query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 WHERE EMP_ID IN (1, 3, 5);
----
3

# --- Aggregation on top of the scan ----------------------------------------

query III
SELECT DEPT_NO, COUNT(*), CAST(AVG(SALARY) AS DECIMAL(10,2))
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
 GROUP BY DEPT_NO ORDER BY DEPT_NO;
----
600	3	85166.92
700	1	71200.00
900	1	65000.75

# --- Federated join with an in-memory CTE ----------------------------------

statement ok
CREATE TEMP TABLE dept_label(dept VARCHAR, label VARCHAR);

statement ok
INSERT INTO dept_label VALUES ('600','Engineering'),('700','Sales'),('900','Ops');

query II
SELECT e.EMP_NAME, d.label
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE') e
  JOIN dept_label d ON e.DEPT_NO = d.dept
 ORDER BY e.EMP_ID;
----
Alice Andersson	Engineering
Bob Brown	Engineering
Carlos Chen	Ops
Diana Davis	Engineering
Erik Eklund	Sales

# --- Named-parameter overrides ---------------------------------------------

query I
SELECT COUNT(*) FROM firebird_scan(
    '${FIREBIRD_TEST_DB}', 'EMPLOYEE',
    user='SYSDBA', password='${ISC_PASSWORD}', charset='UTF8');
----
5

# --- PK-range partition overrides (parallel scan) --------------------------
# Forcing N=3 partitions on a 5-row table exercises the parallel path
# and confirms partitions still return every row exactly once.

query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', partitions=3);
----
5

# Single-threaded path is selectable with partitions=1 (skips the PK probe).
query II
SELECT EMP_ID, EMP_NAME FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', partitions=1)
 ORDER BY EMP_ID LIMIT 2;
----
1	Alice Andersson
2	Bob Brown

# Sum across all rows is identical whether we partition or not — guards
# against off-by-one / duplicate-row bugs in the partition boundaries.
query I
SELECT SUM(EMP_ID) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', partitions=4);
----
15

# --- firebird_tables() — discovery -----------------------------------------

# EMPLOYEE is present, has 8 columns (incl. NAME_LEN computed column), PK on EMP_ID.
query IIII
SELECT table_name, column_count, has_pk, pk_column
  FROM firebird_tables('${FIREBIRD_TEST_DB}')
 WHERE table_name = 'EMPLOYEE';
----
EMPLOYEE	8	true	EMP_ID

# --- firebird_attach_sql() — view-based "attach" ----------------------------

# First emitted statement is the CREATE SCHEMA, all others are CREATE VIEW.
query II
WITH t AS (SELECT row_number() OVER () AS rn, sql FROM firebird_attach_sql('${FIREBIRD_TEST_DB}', 'fb'))
SELECT (rn = 1 AND sql LIKE 'CREATE SCHEMA%')   AS schema_first,
       (rn > 1  AND sql LIKE 'CREATE OR REPLACE VIEW%') AS rest_are_views
  FROM t WHERE rn IN (1, 2);
----
true	false
false	true

# Every CREATE VIEW wraps a firebird_scan call.
query I
SELECT COUNT(*) > 0 FROM firebird_attach_sql('${FIREBIRD_TEST_DB}', 'fb')
 WHERE sql LIKE '%firebird_scan%' AND sql LIKE '%EMPLOYEE%';
----
true

# Emitted SQL is well-formed: ends with `;`, references the requested
# schema name and a real Firebird table.
query III
WITH t AS (SELECT sql FROM firebird_attach_sql('${FIREBIRD_TEST_DB}', 'fb'))
SELECT bool_and(sql LIKE '%;'),
       bool_or (sql LIKE '%fb"."EMPLOYEE"%'),
       bool_and(sql LIKE 'CREATE SCHEMA%' OR sql LIKE 'CREATE OR REPLACE VIEW%')
  FROM t;
----
true	true	true

# End-to-end works in the CLI (verified by hand: `COPY … TO 'attach.sql'`
# followed by `.read attach.sql`, then SELECT from fb.EMPLOYEE returns
# the same rows as firebird_scan(... EMPLOYEE)). The .read step is a
# CLI dot-command that the sqllogictest harness doesn't execute, so we
# stop the automated test before .read here.

# --- Views (RDB$RELATION_TYPE = 1) -----------------------------------------
# Views show up alongside tables and scan exactly like a base table.

query I
SELECT kind FROM firebird_tables('${FIREBIRD_TEST_DB}')
 WHERE table_name = 'V_ACTIVE_EMP';
----
view

query III
SELECT EMP_ID, EMP_NAME, DEPT_NO
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_ACTIVE_EMP')
 ORDER BY EMP_ID;
----
1	Alice Andersson	600
2	Bob Brown	600
4	Diana Davis	600
5	Erik Eklund	700

# --- BLOB binary (SUB_TYPE 0) ----------------------------------------------
# Verifies the BLOB-read path that doesn't degrade to VARCHAR.

# Schema discovery surfaces the binary BLOB column as DuckDB BLOB
# (not VARCHAR, which is what SUB_TYPE 1 maps to).
query I
SELECT typeof(PAYLOAD)
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'FILE_STORAGE')
 WHERE FILE_ID = 1;
----
BLOB

# Payload bytes round-trip exactly — octet_length matches the recorded size.
query II
SELECT FILE_ID, octet_length(PAYLOAD)
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'FILE_STORAGE')
 ORDER BY FILE_ID;
----
1	6
2	NULL
3	5

# --- Charset handling ------------------------------------------------------
#
# DuckDB strings are UTF-8 internally. Tell the user clearly when they
# pick a charset that would deliver non-UTF-8 bytes — silently passing
# them through would crash deeper in DuckDB's utf8proc.

statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', charset='WIN1252') LIMIT 1;
----
charset='WIN1252' would deliver non-UTF-8 bytes

statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', charset='ISO8859_1') LIMIT 1;
----
non-UTF-8

# UTF-8 (with or without the dash) + the byte-pass-through aliases pass.
query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', charset='UTF-8');
----
5

# --- Error paths ------------------------------------------------------------

# Unknown table — bind should fail with a clear message.
statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'DOES_NOT_EXIST') LIMIT 1;
----
firebird_scan: table 'DOES_NOT_EXIST'

# ---------------------------------------------------------------------------
#  Type Lossless Hardening (#33): a view's computed/aggregate column can
#  have a catalog-frozen type (set at CREATE VIEW time) that disagrees
#  with Firebird's live runtime type for the identical expression today.
#  V_DEPT_HEADCOUNT's TOTAL_SALARY (SUM(EMPLOYEE.SALARY), SALARY is
#  NUMERIC(10,2)) is catalogued as INT128-backed DECIMAL(38,2), but
#  Firebird's live SUM() promotion produces BIGINT-backed NUMERIC(18,2).
#  Before the fix: "INTERNAL Error: Expected vector of type INT64, but
#  found vector of type INT128". This must not just avoid crashing — the
#  value AND the reconciled DuckDB type must both be correct.
# ---------------------------------------------------------------------------

statement ok
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_DEPT_HEADCOUNT');

# TEMP DIAGNOSTIC for issue #42 (reverting once the real CI-observed type
# is known) -- selecting typeof() directly (not wrapped in an equality
# comparison) against a deliberately-wrong expected value, so the test
# framework's own "Expected / Actual" failure output prints the REAL
# typeof() string in the CI log.
query T
SELECT typeof(TOTAL_SALARY)
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_DEPT_HEADCOUNT') LIMIT 1;
----
ZZZ_ISSUE42_PROBE_ZZZ

# V_DEPT_HEADCOUNT is defined as a self-join (EMPLOYEE e JOIN EMPLOYEE m
# ON m.DEPT_NO = e.DEPT_NO, GROUP BY e.DEPT_NO — see
# scripts/setup_test_firebird.sh), so each department's TOTAL_SALARY is
# headcount * sum(salary) for that department, not a plain sum(salary).
# The independent check below reproduces that fan-out directly from
# EMPLOYEE (never touching the view), so it proves the reconciled value
# is exactly right, not just "didn't crash".
query I
SELECT SUM(TOTAL_SALARY) = (
    SELECT SUM(cnt * total)
      FROM (SELECT COUNT(*) AS cnt, SUM(SALARY) AS total
              FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE')
             GROUP BY DEPT_NO)
  )
  FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_DEPT_HEADCOUNT');
----
true
