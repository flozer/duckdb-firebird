# name: test/sql/firebird_paging.test
# description: row_limit + row_offset physical paging
# group: [firebird]
#
# Exercises the `row_offset=M` named parameter introduced in the
# v0.5 paging milestone. The pair (row_limit=N, row_offset=M) emits
# `ROWS M+1 TO M+N` in the Firebird SQL — 1-based, inclusive.
#
# Contract decisions (v0.5):
#   * `row_offset` REQUIRES `row_limit` — pure offset is rejected
#     at bind time (Firebird's ROWS clause is bound-pair; offset-only
#     paging is expensive and surprising).
#   * Paging is global slice semantics. To prevent
#     `row_limit=100, partitions=4` from returning 400 rows, the bind
#     step silently forces `partitions=1` whenever row_limit or
#     row_offset is set — the v0.4 syntax
#     `firebird_scan(..., row_limit=100)` continues to work and now
#     guarantees serial execution.
#   * An explicit `partitions=N` (N > 1) combined with row_limit /
#     row_offset is rejected at bind time so the conflict can't pass
#     silently.
#   * `row_offset + row_limit` must fit in idx_t; the bind step
#     rejects values that would overflow the Firebird SQL.
#
# Requires the EMPLOYEE fixture (5 rows, EMP_ID 1..5).

require firebird

require-env FIREBIRD_TEST_DB

# --- row_limit standalone — preserves v0.4 syntax -----------------

query I
SELECT EMP_ID FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', row_limit=2)
 ORDER BY EMP_ID;
----
1
2

# --- row_limit + explicit partitions=1 — same result ---------------

query I
SELECT EMP_ID FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                                  row_limit=2, partitions=1)
 ORDER BY EMP_ID;
----
1
2

# --- row_offset + row_limit — new in v0.5, partitions implicit 1 ---

query I
SELECT EMP_ID FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                                  row_limit=2, row_offset=2)
 ORDER BY EMP_ID;
----
3
4

# --- row_offset=0 + row_limit=3 == row_limit=3 alone ---------------

query I
SELECT EMP_ID FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                                  row_limit=3, row_offset=0)
 ORDER BY EMP_ID;
----
1
2
3

# --- row_offset past the end returns zero rows ---------------------

query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                                    row_limit=2, row_offset=100);
----
0

# --- row_offset without row_limit raises ---------------------------

statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', row_offset=2);
----
row_offset requires row_limit

# --- Negative offset rejected --------------------------------------

statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                            row_limit=1, row_offset=-1);
----
row_offset must be >= 0

# --- Paging + explicit partitions > 1 rejected --------------------
# The "auto" case (partitions=0 default) is *not* rejected — it's
# coerced to partitions=1 internally so the v0.4 row_limit syntax
# keeps working. Only an explicit `partitions=N` (N > 1) raises.

statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                            row_limit=2, partitions=4);
----
partitions > 1

statement error
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                            row_limit=2, row_offset=2, partitions=2);
----
partitions > 1

# --- Combine with filter pushdown — same slice contract -----------

query I
SELECT EMP_ID FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE',
                                  row_limit=2, row_offset=1)
 WHERE DEPT_NO = '600'
 ORDER BY EMP_ID;
----
2
4

# ---------------------------------------------------------------------------
#  Smart Scan Planning Report: ROWS pagination must always pair with a
#  server-side ORDER BY, using a decision order:
#    1. single-column numeric PK -> ORDER BY <pk> ASC
#    2. base table, no such PK -> ORDER BY RDB$DB_KEY
#    3. simple view (no join/group-by/aggregate), no such PK -> ORDER BY RDB$DB_KEY
#    4. heavy view / uninspectable source -> do NOT push ROWS; slice locally
# ---------------------------------------------------------------------------

require-env ISC_PASSWORD

statement ok
ATTACH '${FIREBIRD_TEST_DB}' AS fb (TYPE firebird);

# Case 1: table with a single-column numeric PK (EMPLOYEE, EMP_ID INTEGER) ->
# ORDER BY "EMP_ID" ASC must be pushed alongside ROWS. This also proves the
# PK probe now runs even when paging forces partitions_override=1 — it used
# to be skipped whenever partitions_override==1, which paging always forces,
# silently making the PK-first decision unreachable (fixed in this task).

statement ok
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'EMPLOYEE', row_limit=2);

query T
SELECT remote_sql LIKE '%ORDER BY "EMP_ID" ASC%' AND remote_sql LIKE '%ROWS%'
  FROM firebird_last_query();
----
true

# Case 2: PK-less base table (TNO_INDEX, from the firebird_index_profile
# item — zero index, zero PK). Two ROWS windows must not overlap: the same
# row must not appear on both pages (proves RDB$DB_KEY ordering is stable
# across pages within one scan).

statement ok
CREATE OR REPLACE TABLE t_page1 AS
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'TNO_INDEX',
                            row_limit=1, row_offset=0);

statement ok
CREATE OR REPLACE TABLE t_page2 AS
SELECT * FROM firebird_scan('${FIREBIRD_TEST_DB}', 'TNO_INDEX',
                            row_limit=1, row_offset=1);

query I
SELECT COUNT(*) FROM (SELECT * FROM t_page1 INTERSECT SELECT * FROM t_page2);
----
0

query T
SELECT remote_sql LIKE '%ORDER BY RDB$DB_KEY%' AND remote_sql LIKE '%ROWS%'
  FROM firebird_last_query();
----
true

# Case 3: simple view (V_ACTIVE_EMP: `SELECT EMP_ID, EMP_NAME, DEPT_NO FROM
# EMPLOYEE WHERE ACTIVE = TRUE` — WHERE-only, no JOIN/GROUP BY/aggregate),
# no PK exposed through the view scan path -> ORDER BY RDB$DB_KEY must be
# pushed alongside ROWS.
#
# Deviation from the design brief's literal Case 3: firebird_explain_pushdown's
# own capture-only Build() call only reflects the real row_limit=/row_offset=
# named-parameter pushdown (bd.limit_override/bd.offset_override), and
# explain_pushdown explicitly rejects direct firebird_scan(...) calls in its
# input SQL (see firebird_explain_pushdown.test's "direct firebird_scan(...)
# is not supported here" case) — so there is no query text that reaches
# WalkPlan with a named-param limit set, and remote_sql there can never
# contain a ROWS clause regardless of this task's fix. Verified instead via
# firebird_last_query(), which captures the real remote_sql of an actually-
# executed firebird_scan() call — a strictly stronger check than a capture-
# only re-derivation would have been anyway.

statement ok
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_ACTIVE_EMP', row_limit=1);

query T
SELECT remote_sql LIKE '%ORDER BY RDB$DB_KEY%' AND remote_sql LIKE '%ROWS%'
  FROM firebird_last_query();
----
true

# Correctness: exactly 1 row returned, not all 4 (V_ACTIVE_EMP has 4 active
# rows in the fixture, verified live) -- proves the pushed ROWS clause is
# actually enforced server-side for this case, not just present in the SQL.

query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_ACTIVE_EMP', row_limit=1);
----
1

# Case 4a: heavy view (V_DEPT_HEADCOUNT) — no ROWS clause should ever
# appear in remote_sql for this target, regardless of any limit context.

query T
SELECT remote_sql NOT LIKE '%ROWS%' FROM firebird_explain_pushdown(
    'SELECT * FROM fb.main.V_DEPT_HEADCOUNT') LIMIT 1;
----
true

# Case 4b (CRITICAL correctness): row_limit/row_offset against the heavy
# view via the actual scanner (not explain_pushdown) — the local-slice
# fallback must bound the result to exactly N rows, never "everything".
# V_DEPT_HEADCOUNT groups EMPLOYEE by DEPT_NO; the fixture has exactly 3
# distinct DEPT_NO groups (verified live: `SELECT COUNT(*) FROM
# V_DEPT_HEADCOUNT` = 3), so row_limit=2 must return exactly 2 rows, not
# all 3 — a coincidental full-return would not prove the fix.
#
# Projected to DEPT_NO, HEADCOUNT only (dropping TOTAL_SALARY, a
# NUMERIC(38,2) expression column): scanning that column via firebird_scan()
# hits a pre-existing, unrelated bug (`INTERNAL Error: Expected vector of
# type INT64, but found vector of type INT128`) reproducible even on a
# plain SELECT * with no row_limit at all — confirmed out of scope for this
# task (firebird_types.cpp / FirebirdAppendValue decimal-width handling,
# not touched by any file in Task 4's scope). Flagged in the implementer
# report for separate follow-up.

statement ok
CREATE OR REPLACE TABLE t_heavy_sliced AS
SELECT DEPT_NO, HEADCOUNT FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_DEPT_HEADCOUNT',
                            row_limit=2);

query I
SELECT COUNT(*) FROM t_heavy_sliced;
----
2

# Case 4b corollary: confirms the mechanism — no ROWS clause was pushed to
# Firebird at all for the local-slice fallback; the slice happened
# client-side in the fetch loop instead.

query T
SELECT remote_sql NOT LIKE '%ROWS%' FROM firebird_last_query();
----
true

# Case 4b, offset exercised too: local slicing must also honor row_offset
# (not just row_limit) — proves the rows_skipped counter in the fetch loop,
# not only the rows_emitted cap.

query I
SELECT COUNT(*) FROM firebird_scan('${FIREBIRD_TEST_DB}', 'V_DEPT_HEADCOUNT',
                                    row_limit=1, row_offset=1);
----
1
