# name: test/sql/firebird_profile_table.test
# description: Phase 4 firebird_profile_table - argument/qualified-name
#              validation, object type, PK detection, index listing,
#              watermark / filter heuristics, full-scan risk, partition
#              recommendation, warnings, no-leak.
# group: [firebird]
#
# Requires the EMPLOYEE / FILE_STORAGE / TPK_COMPOSITE / V_ACTIVE_EMP
# fixtures from scripts/setup_test_firebird.sh.

require firebird

require-env FIREBIRD_TEST_DB

require-env ISC_PASSWORD

# ---------------------------------------------------------------------------
#  Argument + qualified-name validation. Errors must mention the function
#  name so the caller doesn't have to guess what they're looking at.
# ---------------------------------------------------------------------------

statement error
SELECT * FROM firebird_profile_table(NULL);
----
firebird_profile_table(qualified_name VARCHAR): qualified_name is required

statement error
SELECT * FROM firebird_profile_table('fb.main.EMPLOYEE.EXTRA');
----
firebird_profile_table(qualified_name VARCHAR): expected

statement error
SELECT * FROM firebird_profile_table('fb.dbo.EMPLOYEE');
----
firebird_profile_table: schema 'dbo' is not exposed

statement error
SELECT * FROM firebird_profile_table('nope_does_not_exist_xyz.main.EMPLOYEE');
----
firebird_generate_dbt_sources: no attached catalog named 'nope_does_not_exist_xyz'

statement error
SELECT * FROM firebird_profile_table('memory.main.EMPLOYEE');
----
catalog 'memory' is not a Firebird ATTACH

# ---------------------------------------------------------------------------
#  Happy-path: ATTACH the fixture and snapshot each profile into a local
#  DuckDB table so every assertion below can scan the same row.
# ---------------------------------------------------------------------------

statement ok
ATTACH '${FIREBIRD_TEST_DB}' AS fb (TYPE firebird);

statement ok
CREATE OR REPLACE TABLE t_prof_emp AS
SELECT * FROM firebird_profile_table('fb.main.EMPLOYEE');

# Exactly one row.

query I
SELECT COUNT(*) FROM t_prof_emp;
----
1

# Object type + PK detection for a single-column INTEGER PK table.

query TTT
SELECT object_type, has_primary_key, primary_key_columns
FROM t_prof_emp;
----
TABLE	true	[EMP_ID]

# The PK index shows up in the index list, flagged PK and UNIQUE.

query T
SELECT list_aggr(indexes, 'string_agg', '|') LIKE '%EMP_ID%PK%'
FROM t_prof_emp;
----
true

# Expression / computed index (EMP_UPPER_NAME_IDX COMPUTED BY (UPPER(EMP_NAME)))
# carries no RDB$INDEX_SEGMENTS rows. It must render as "(expression)", never
# with empty parentheses, and must not leak the expression BLR/text.

query T
SELECT list_aggr(indexes, 'string_agg', '|') LIKE '%EMP_UPPER_NAME_IDX (expression)%'
FROM t_prof_emp;
----
true

query T
SELECT list_aggr(indexes, 'string_agg', '|') NOT LIKE '%()%'
FROM t_prof_emp;
----
true

# Watermark candidates: INTEGER + DATE columns qualify (EMP_ID, HIRE_DATE).
# DECIMAL / VARCHAR / BOOLEAN / BLOB do not.

query T
SELECT list_contains(watermark_candidates, 'EMP_ID')
   AND list_contains(watermark_candidates, 'HIRE_DATE')
   AND NOT list_contains(watermark_candidates, 'SALARY')
   AND NOT list_contains(watermark_candidates, 'EMP_NAME')
FROM t_prof_emp;
----
true

# Filter candidates: EMP_ID is indexed (PK) and numeric -> good filter.

query T
SELECT list_contains(filter_candidates, 'EMP_ID')
FROM t_prof_emp;
----
true

# Risk + recommended partitions: tiny table (PK range well under
# PickPartitionCount's partitioning floor) -> LOW, serial.

query TI
SELECT full_scan_risk, recommended_partitions
FROM t_prof_emp;
----
LOW	1

# Adaptive parallel recommendation (Phase 4 #7). A small numeric-PK range
# recommends serial with an explicit "range is small" note, and must NOT
# emit the advisory/partition-count or server-side-parallelism caveats
# (those only apply when partitions > 1 is recommended).

query T
SELECT list_aggr(warnings, 'string_agg', '|') LIKE '%range is small%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%advisory%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%server-side parallelism%'
FROM t_prof_emp;
----
true

# The qualified-name short form (catalog.table) resolves to the same table.

query T
SELECT (SELECT object_type FROM firebird_profile_table('fb.EMPLOYEE'))
     = (SELECT object_type FROM t_prof_emp);
----
true

# ---------------------------------------------------------------------------
#  Composite PK: has_primary_key is true, but the parallel lever needs a
#  single-column numeric PK, so partitions=1, risk HIGH, with a warning.
# ---------------------------------------------------------------------------

statement ok
CREATE OR REPLACE TABLE t_prof_comp AS
SELECT * FROM firebird_profile_table('fb.main.TPK_COMPOSITE');

query TTI
SELECT has_primary_key, full_scan_risk, recommended_partitions
FROM t_prof_comp;
----
true	HIGH	1

query T
SELECT list_aggr(warnings, 'string_agg', '|') LIKE '%Primary key is composite%'
FROM t_prof_comp;
----
true

# ---------------------------------------------------------------------------
#  View: object_type VIEW, no PK, no indexes, HIGH risk, serial, with the
#  heavy-view materialization pointer.
# ---------------------------------------------------------------------------

statement ok
CREATE OR REPLACE TABLE t_prof_view AS
SELECT * FROM firebird_profile_table('fb.main.V_ACTIVE_EMP');

query TTTI
SELECT object_type, has_primary_key, full_scan_risk, recommended_partitions
FROM t_prof_view;
----
VIEW	false	HIGH	1

query T
SELECT len(indexes) = 0 AND len(primary_key_columns) = 0
FROM t_prof_view;
----
true

query T
SELECT list_aggr(warnings, 'string_agg', '|') LIKE '%VIEW%materializing%'
FROM t_prof_view;
----
true

# V_ACTIVE_EMP has a WHERE filter and no join/aggregation. Heavy-view
# inspection must NOT emit join / aggregation / no-WHERE warnings for it.

query T
SELECT list_aggr(warnings, 'string_agg', '|') NOT LIKE '%JOIN%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%aggregation%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%no WHERE filter%'
FROM t_prof_view;
----
true

# ---------------------------------------------------------------------------
#  Heavy-view diagnostics (Phase 4 #2). Conservative, factual flags derived
#  from the stored view SELECT text — never the text itself.
#
#  V_ALL_EMP    : SELECT ... FROM EMPLOYEE  (no WHERE, no join, no aggregate)
#  V_DEPT_HEADCOUNT : self-JOIN + GROUP BY + COUNT/SUM, no WHERE
# ---------------------------------------------------------------------------

statement ok
CREATE OR REPLACE TABLE t_prof_vall AS
SELECT * FROM firebird_profile_table('fb.main.V_ALL_EMP');

# No-WHERE view: emits the no-filter warning, but NOT join/aggregation.

query T
SELECT list_aggr(warnings, 'string_agg', '|') LIKE '%no WHERE filter%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%JOIN%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%aggregation%'
FROM t_prof_vall;
----
true

statement ok
CREATE OR REPLACE TABLE t_prof_vhc AS
SELECT * FROM firebird_profile_table('fb.main.V_DEPT_HEADCOUNT');

# Heavy view: JOIN + aggregation + no-WHERE all flagged.

query T
SELECT list_aggr(warnings, 'string_agg', '|') LIKE '%contains a JOIN%'
   AND list_aggr(warnings, 'string_agg', '|') LIKE '%contains aggregation%'
   AND list_aggr(warnings, 'string_agg', '|') LIKE '%no WHERE filter%'
FROM t_prof_vhc;
----
true

# Still a VIEW with the base materialization pointer + HIGH risk.

query TT
SELECT object_type, full_scan_risk FROM t_prof_vhc;
----
VIEW	HIGH

# The raw view SELECT text must never leak into warnings (no column-list /
# FROM / table names from the definition).

query T
SELECT list_aggr(warnings, 'string_agg', '|') NOT LIKE '%TOTAL_SALARY%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%FROM EMPLOYEE%'
FROM t_prof_vhc;
----
true

# Literal-noise view: keyword-shaped text (JOIN / GROUP BY / WHERE) lives
# inside a single string literal that also contains an SQL-escaped doubled
# quote (O''Brien). The token scan must blank the literal (correctly
# consuming the '') and therefore must NOT flag JOIN or aggregation, and
# must NOT treat the literal WHERE as a real filter. The view has no real
# WHERE, so the no-WHERE warning IS expected.

statement ok
CREATE OR REPLACE TABLE t_prof_lit AS
SELECT * FROM firebird_profile_table('fb.main.V_LITERAL_NOISE');

query T
SELECT list_aggr(warnings, 'string_agg', '|') NOT LIKE '%contains a JOIN%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%contains aggregation%'
   AND list_aggr(warnings, 'string_agg', '|') LIKE '%no WHERE filter%'
FROM t_prof_lit;
----
true

# Whitespace-split keywords: V_MULTILINE_KW has a real JOIN, GROUP BY and
# WHERE, but formatted across newlines/tabs (INNER\nJOIN, GROUP\n  BY,
# WHERE after indentation). The scan must collapse whitespace and still
# detect join + aggregation. It HAS a real WHERE, so the no-WHERE warning
# must NOT fire.

statement ok
CREATE OR REPLACE TABLE t_prof_ml AS
SELECT * FROM firebird_profile_table('fb.main.V_MULTILINE_KW');

query T
SELECT list_aggr(warnings, 'string_agg', '|') LIKE '%contains a JOIN%'
   AND list_aggr(warnings, 'string_agg', '|') LIKE '%contains aggregation%'
   AND list_aggr(warnings, 'string_agg', '|') NOT LIKE '%no WHERE filter%'
FROM t_prof_ml;
----
true

# ---------------------------------------------------------------------------
#  No-leak: no profile field may contain the database path, username,
#  password, or a URI form of the connection string.
# ---------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT list_aggr(list_concat(
        [table_name, object_type, full_scan_risk],
        list_concat(indexes, list_concat(warnings,
            list_concat(watermark_candidates, filter_candidates)))
    ), 'string_agg', '|') AS blob
    FROM t_prof_emp
)
WHERE blob LIKE '%SYSDBA%'
   OR blob LIKE '%masterkey%'
   OR blob LIKE '%firebird://%'
   OR blob LIKE '%.fdb%'
   OR blob LIKE '%password%';
----
0

# ---------------------------------------------------------------------------
#  Structured alerts (v0.8): alerts is 1:1 with warnings, carries a stable
#  code + LOW/MEDIUM/HIGH severity, message identical to the warnings text.
# ---------------------------------------------------------------------------

# alerts column exists and is LIST(STRUCT(code,severity,message)).
query T
SELECT typeof(alerts) FROM firebird_profile_table('fb.main.V_ACTIVE_EMP');
----
STRUCT(code VARCHAR, severity VARCHAR, message VARCHAR)[]

# Invariant: same length as warnings.
query T
SELECT len(alerts) = len(warnings) FROM firebird_profile_table('fb.main.V_ACTIVE_EMP');
----
true

# Invariant: alerts[i].message == warnings[i], element-by-element (zipped UNNEST).
query I
SELECT COUNT(*) FROM (
  SELECT UNNEST(warnings) AS w,
         UNNEST(list_transform(alerts, a -> a.message)) AS m
  FROM firebird_profile_table('fb.main.V_ACTIVE_EMP')
) t
WHERE w IS DISTINCT FROM m;
----
0

# Severity domain: every alert severity is LOW/MEDIUM/HIGH.
query I
SELECT COUNT(*) FROM (
  SELECT UNNEST(alerts) AS a FROM firebird_profile_table('fb.main.V_ACTIVE_EMP')
) t
WHERE a.severity NOT IN ('LOW', 'MEDIUM', 'HIGH');
----
0

# Deterministic HIGH alert: a view raises view_no_scan_lever / HIGH.
query TT
SELECT a.code, a.severity FROM (
  SELECT UNNEST(alerts) AS a FROM firebird_profile_table('fb.main.V_ACTIVE_EMP')
) t
WHERE a.code = 'view_no_scan_lever';
----
view_no_scan_lever	HIGH

# Deterministic LOW alert: a composite PK raises composite_pk_serial / LOW.
query TT
SELECT a.code, a.severity FROM (
  SELECT UNNEST(alerts) AS a FROM firebird_profile_table('fb.main.TPK_COMPOSITE')
) t
WHERE a.code = 'composite_pk_serial';
----
composite_pk_serial	LOW

# A table with a single numeric PK raises no view/no-PK HIGH alerts.
query I
SELECT COUNT(*) FROM (
  SELECT UNNEST(alerts) AS a FROM firebird_profile_table('fb.main.EMPLOYEE')
) t
WHERE a.code IN ('no_primary_key', 'view_no_scan_lever');
----
0

statement ok
DETACH fb;
