# name: test/sql/firebird_none_charset.test
# description: CHARACTER SET NONE + none_encoding feature
# group: [firebird]
#
# Requires the fixture from scripts/fixture_none_charset.sql applied
# to a database whose default charset is NONE (scripts/fixture_create_none.sql
# bootstraps one at C:\fbtest\none.fdb / /tmp/fbtest/none.fdb).
#
# Environment:
#   FIREBIRD_NONE_DB    path to the NONE-charset database

require firebird

require-env FIREBIRD_NONE_DB

# --- ASCII row passes strict + every other encoding ------------------

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='strict')
 WHERE ID = 1;
----
1	pure ascii

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE ID = 1;
----
1	pure ascii

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='iso8859_1')
 WHERE ID = 1;
----
1	pure ascii

# --- WIN1252 / Latin-1 row ------------------------------------------

# Strict must reject when a non-ASCII byte appears.
statement error
SELECT * FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='strict')
 WHERE ID = 2;
----
CHARACTER SET NONE

# win1252 decoding: 0xE3 → ã, 0xE7 → ç (matches Latin-1 for these positions).
query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE ID = 2;
----
2	São Paulo

# Latin-1 / iso8859_1 round-trip — same result for bytes in 0xA0..0xFF.
query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='iso8859_1')
 WHERE ID = 2;
----
2	São Paulo

# --- CP1252-only bytes (curly quotes 0x93 / 0x94) -------------------

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE ID = 3;
----
3	“hi”

# Strict must reject these — they're not valid UTF-8 either.
statement error
SELECT * FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='strict')
 WHERE ID = 3;
----
CHARACTER SET NONE

# --- blob mode surfaces the raw bytes -------------------------------

query I
SELECT typeof(LABEL) FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='blob')
 WHERE ID = 1;
----
BLOB

query I
SELECT octet_length(LABEL) FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='blob')
 WHERE ID = 3;
----
4

# --- Text BLOB (NOTE column) ----------------------------------------
# Same transcoding policy applies to text BLOBs whose CHARACTER SET is NONE.

query II
SELECT ID, NOTE FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE ID = 3;
----
3	€

statement error
SELECT * FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='strict')
 WHERE ID = 3;
----
CHARACTER SET NONE

# --- Bad none_encoding rejected at parse time -----------------------

statement error
SELECT * FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='utf16');
----
unknown none_encoding

# --- ATTACH respects none_encoding ----------------------------------

statement ok
ATTACH '${FIREBIRD_NONE_DB}' AS att (TYPE firebird, user 'SYSDBA', password 'masterkey', none_encoding 'win1252');

query II
SELECT ID, LABEL FROM att.main.TXT WHERE ID = 2;
----
2	São Paulo

# --- Filter on a NONE text column under ATTACH: must return the row
# whose post-transcode value matches the UTF-8 literal. Before the
# v0.4.2 supports_pushdown_type / filter_prune fix, this query would
# push the predicate into Firebird, compare raw CP1252 bytes against
# 'São Paulo' UTF-8 bytes, and silently miss the row.

query II
SELECT ID, LABEL FROM att.main.TXT WHERE LABEL = 'São Paulo';
----
2	São Paulo

statement ok
DETACH att;

# --- CONSTANT_COMPARISON via firebird_scan() —---------------------

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE LABEL = 'São Paulo';
----
2	São Paulo

# --- IN_FILTER on a NONE text column ------------------------------

query II rowsort
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE LABEL IN ('São Paulo', 'pure ascii')
 ORDER BY ID;
----
1	pure ascii
2	São Paulo

# --- AND: numeric filter (pushable) + text filter on NONE col -----
# The numeric predicate goes to Firebird; the text predicate stays
# in DuckDB, evaluated post-transcode.

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT', none_encoding='win1252')
 WHERE ID >= 2
   AND LABEL = 'São Paulo';
----
2	São Paulo

# --- STRICT mode still pushes text filters (no transcoding needed) -
# Row 1 is pure ASCII so the strict path doesn't error here. Verify
# the pushdown path still returns the correct row.

query II
SELECT ID, LABEL FROM firebird_scan('${FIREBIRD_NONE_DB}', 'TXT')
 WHERE LABEL = 'pure ascii';
----
1	pure ascii
